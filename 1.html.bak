              <Reveal delay={400} direction="none" className="w-full h-full flex items-center justify-center relative">
                
                {/* Окно приложения с инлайн-стилем для 3D слежения */}
                <div 
                  className="lapis-mockup relative w-full max-w-[500px] aspect-[4/3] glass-card rounded-2xl border border-white/20 shadow-[0_20px_60px_rgba(0,0,0,0.6)] overflow-hidden bg-[#0F1117]/70 backdrop-blur-2xl"
                  style={{
                    transform: `perspective(1200px) rotateY(${heroMouse.x * 18 - 10}deg) rotateX(${-heroMouse.y * 18 + 3}deg)`,
                    boxShadow: `0 30px 80px rgba(var(--orb-color-1-rgb),${0.15 + Math.abs(heroMouse.x) * 0.15}), 0 0 0 1px rgba(255,255,255,0.08)`,
                  }}
                >
                  <Particles colors={colors} />
                  
                  {/* Шапка окна (macOS style) */}
                  <div className="h-10 border-b border-white/10 bg-white/5 flex items-center px-4 gap-2 relative z-10">
                    <div className="w-3 h-3 rounded-full bg-red-500/80 shadow-[0_0_5px_rgba(239,68,68,0.5)]"></div>
                    <div className="w-3 h-3 rounded-full bg-yellow-500/80 shadow-[0_0_5px_rgba(234,179,8,0.5)]"></div>
                    <div className="w-3 h-3 rounded-full bg-green-500/80 shadow-[0_0_5px_rgba(34,197,94,0.5)]"></div>
                    <div className="ml-auto flex items-center gap-2 text-xs text-gray-400 font-medium">
                      <BookOpen className="w-3 h-3" style={{ color: 'var(--orb-color-1)' }} /> Lapis Workspace
                    </div>
                  </div>
                  
                  {/* Тело приложения (Скелетон-мокап) */}
                  <div className="flex h-[calc(100%-2.5rem)] relative z-10">
