                </div>
              </div>
            </div>
          </Reveal>
        </section>

        {/* --- СЕКЦИЯ 2: STREAK / АКТИВНОСТЬ --- */}
        <section className="py-20 relative z-10">
          <Reveal direction="left">
            <h2 className="text-3xl font-heading mb-10 flex items-center gap-3">
              <Flame className="flame-active" /> Tvoje aktivita
            </h2>
          </Reveal>
          
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            {/* Левая колонка: Heatmap и базовая статистика (Занимает 2/3) */}
            <div className="lg:col-span-2 glass-card rounded-3xl p-8 flex flex-col justify-between hover-target">
              
              {/* Heatmap с разметкой и центрированием */}
              <div className="w-full overflow-x-auto hide-scrollbar mb-6">
                <div className="flex flex-col items-center min-w-max mx-auto">
                  
                  <div className="flex gap-3">
                    {/* Левые подписи (Дни недели) */}
                    <div className="flex flex-col gap-2 text-[10px] text-gray-500 font-medium text-right mt-6">
                      <div className="h-4 leading-4">Po</div>
                      <div className="h-4 leading-4"></div>
                      <div className="h-4 leading-4">St</div>
                      <div className="h-4 leading-4"></div>
                      <div className="h-4 leading-4">Pá</div>
                      <div className="h-4 leading-4"></div>
                      <div className="h-4 leading-4">Ne</div>
                    </div>

                    {/* Сетка и верхние подписи (Месяцы) */}
                    <div className="flex flex-col gap-2">
                      <div className="flex justify-between text-[10px] text-gray-500 font-medium px-1">
                        <span>Lis</span>
                        <span>Pro</span>
                        <span>Led</span>
                      </div>
                      <div className="flex gap-2">
                        {heatmapData.map((col, colIndex) => (
                          <div key={colIndex} className="flex flex-col gap-2">
                            {col.map((bg, rowIndex) => {
                              const delay = (colIndex * 7 + rowIndex) * 10; // Stagger effect
                              return (
                                <div 
                                  key={rowIndex} 
                                  className="w-4 h-4 rounded-sm heatmap-cell transition-colors duration-300"
                                  style={{ 
                                    backgroundColor: bg === '0' ? 'rgba(255,255,255,0.05)' : `rgba(var(--orb-color-1-rgb), ${bg})`, 
                                    animationDelay: `${delay}ms` 
                                  }}
                                ></div>
                              );
                            })}
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  {/* Легенда (Меньше / Больше) */}
                  <div className="flex items-center gap-2 text-[10px] text-gray-500 self-end mt-4 mr-1">
                    <span>Méně</span>
                    <div className="flex gap-1">
                      <div className="w-3 h-3 rounded-sm bg-white/5"></div>
                      <div className="w-3 h-3 rounded-sm transition-colors duration-300" style={{ backgroundColor: 'rgba(var(--orb-color-1-rgb), 0.3)' }}></div>
                      <div className="w-3 h-3 rounded-sm transition-colors duration-300" style={{ backgroundColor: 'rgba(var(--orb-color-1-rgb), 0.6)' }}></div>
                      <div className="w-3 h-3 rounded-sm transition-colors duration-300" style={{ backgroundColor: 'rgba(var(--orb-color-1-rgb), 1)' }}></div>
                    </div>
                    <span>Více</span>
                  </div>

                </div>
              </div>

              {/* Stats Row */}
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6 pt-6 border-t border-white/10 mt-auto">
                <div className="flex flex-col">
                  <span className="text-gray-400 text-sm mb-1">Streak</span>
                  <span className="text-4xl font-heading font-semibold text-white">
                    <CountUp end={32} /> <span className="text-lg font-normal text-gray-500">dní v řadě</span>
                  </span>
                </div>
                <div className="flex flex-col">
                  <span className="text-gray-400 text-sm mb-1">Kartičky</span>
                  <span className="text-4xl font-heading font-semibold text-white">
                    <CountUp end={248} /> <span className="text-lg font-normal text-gray-500">karet</span>
                  </span>
                </div>
                <div className="flex flex-col">
                  <span className="text-gray-400 text-sm mb-1">Testy</span>
                  <span className="text-4xl font-heading font-semibold text-white">
                    <CountUp end={14} /> <span className="text-lg font-normal text-gray-500">dokončeno</span>
                  </span>
                </div>
              </div>
            </div>

            {/* Правая колонка: Příští události (Занимает 1/3) */}
            <Reveal delay={200} direction="up" className="h-full">
              <div className="glass-card rounded-3xl p-8 h-full flex flex-col relative overflow-hidden group hover-target">
                {/* Эффект свечения на фоне карточки */}
                <div className="absolute -top-10 -right-10 w-48 h-48 blur-3xl rounded-full transition-all opacity-10 group-hover:opacity-20" style={{ backgroundColor: 'var(--orb-color-1)' }}></div>

                <h3 className="text-lg font-medium text-white mb-6 flex items-center gap-2 relative z-10">
                  <Calendar className="w-5 h-5" style={{ color: 'var(--orb-color-1)' }} /> Příští události
                </h3>

                <div className="flex flex-col gap-2 relative z-10">
                  
                  {/* Событие 1: Завтра */}
                  <div className="flex gap-4 p-3 -mx-3 rounded-xl hover:bg-white/5 transition-colors group/item cursor-pointer border-l-2 border-transparent hover:border-red-500">
                    <div className="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center flex-shrink-0">
                      <PenTool className="w-5 h-5 text-red-400" />
                    </div>
                    <div className="flex-1">
                      <div className="flex justify-between items-start mb-1">
                        <h4 className="font-medium text-white text-sm">Závěrečný test</h4>
                        <span className="text-[10px] font-bold uppercase tracking-wider text-red-400 bg-red-400/10 px-2 py-0.5 rounded">Zítra</span>
                      </div>
                      <p className="text-xs text-gray-400">Biologie buněk</p>
                    </div>
                  </div>

                  {/* Событие 2: Через 3 дня */}
                  <div className="flex gap-4 p-3 -mx-3 rounded-xl hover:bg-white/5 transition-colors group/item cursor-pointer border-l-2 border-transparent hover:border-yellow-500">
                    <div className="w-10 h-10 rounded-lg bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
                      <FileText className="w-5 h-5 text-yellow-400" />
                    </div>
                    <div className="flex-1">
                      <div className="flex justify-between items-start mb-1">
                        <h4 className="font-medium text-white text-sm">Odevzdání eseje</h4>
                        <span className="text-[10px] font-bold uppercase tracking-wider text-yellow-400 bg-yellow-400/10 px-2 py-0.5 rounded">Za 3 dny</span>
                      </div>
                      <p className="text-xs text-gray-400">Historie Evropy</p>
                    </div>
                  </div>

                  {/* Событие 3: На следующей неделе */}
                  <div className="flex gap-4 p-3 -mx-3 rounded-xl hover:bg-white/5 transition-colors group/item cursor-pointer border-l-2 border-transparent hover:border-[#4DB8FF]">
                    <div className="w-10 h-10 rounded-lg bg-[#4DB8FF]/10 flex items-center justify-center flex-shrink-0">
                      <BookOpen className="w-5 h-5 text-[#4DB8FF]" />
                    </div>
                    <div className="flex-1">
                      <div className="flex justify-between items-start mb-1">
                        <h4 className="font-medium text-white text-sm">Ústní zkoušení</h4>
                        <span className="text-[10px] font-bold uppercase tracking-wider text-[#4DB8FF] bg-[#4DB8FF]/10 px-2 py-0.5 rounded">Příští týden</span>
                      </div>
                      <p className="text-xs text-gray-400">Angličtina B2</p>
                    </div>
                  </div>

                </div>

                <button className="w-full mt-auto pt-6 text-gray-400 hover:text-white text-sm font-medium transition-colors relative z-10 flex justify-center items-center gap-2">
                  Otevřít kalendář <ArrowRight className="w-4 h-4" />
                </button>
              </div>
            </Reveal>

          </div>
        </section>

        {/* --- СЕКЦИЯ 3: ПРОДОЛЖИТЬ С ТОГО МЕСТА --- */}
        <section className="py-20">
          <Reveal delay={100} direction="up">
            <h2 className="text-3xl font-heading mb-10">Pokračuj tam, kde jsi skončil</h2>
          </Reveal>

          <div className="flex gap-6 overflow-x-auto hide-scrollbar py-10 -my-10 px-6 -mx-6 md:px-4 md:-mx-4">
            {[
              { title: "Matematika", clr: "#60a5fa", notes: 12, tests: 2, cards: 145, date: "Dnes, 09:41", icon: <Folder className="text-blue-400" />, delay: 0 },
              { title: "Angličtina B2", clr: "#c084fc", notes: 5, tests: 1, cards: 320, date: "Včera", icon: <Folder className="text-purple-400" />, delay: 100 },
              { title: "Fyzika", clr: "#4ade80", notes: 8, tests: 4, cards: 85, date: "Před 2 dny", icon: <Folder className="text-green-400" />, delay: 200 },
              { title: "Dějepis", clr: "#facc15", notes: 24, tests: 0, cards: 410, date: "Před 3 dny", icon: <Folder className="text-yellow-400" />, delay: 300 },
            ].map((item, idx) => (
              <Reveal key={idx} delay={item.delay} className="w-[85vw] md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] flex-shrink-0">
                <HoloCard item={item} />
              </Reveal>
            ))}
          </div>
        </section>

        {/* Два столбца для секций 4 и 5 (Десктоп) */}
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-12 py-20">
          
          {/* --- СЕКЦИЯ 4: КАРТОЧКИ К ПОВТОРЕНИЮ --- */}
          <section>
            <Reveal direction="right">
              <h2 className="text-3xl font-heading mb-8 flex items-center justify-between">
                Na dnes
                <span className="text-sm font-normal bg-white/5 px-3 py-1 rounded-full" style={{ color: 'var(--orb-color-1)' }}>{tasks.filter(t => !t.completed).length} úkoly</span>
              </h2>
            </Reveal>

            <div className="flex flex-col gap-3 relative">
              {tasks.map((task, idx) => (
                <div 
                  key={task.id} 
                  onClick={() => toggleTask(task.id)}
                  style={{ animationDelay: `${idx * 100}ms` }}
                  className={`glass-card p-4 rounded-xl flex items-center gap-4 group transition-all duration-500 cursor-pointer border-l-2 animate-fade-in-up fill-mode-both hover-target
                    ${task.completed 
                      ? 'opacity-40 grayscale border-l-transparent bg-transparent scale-[0.98]' 
                      : 'hover:bg-white/5 border-l-transparent hover:border-l-[#7C6FF7] scale-100 hover:scale-[1.01]'
                    }
                  `}
                >
                  <div className={`p-3 rounded-lg transition-colors duration-300 ${task.completed ? 'bg-transparent' : 'bg-white/5 group-hover:bg-white/10'}`}>
                    {task.icon}
                  </div>
                  
                  <div className={`font-medium transition-colors duration-300 ${task.completed ? 'text-gray-500' : 'text-white'}`}>
                    <span className={task.completed ? 'strikethrough-animate' : ''}>
                      {task.title}
                    </span>
                  </div>
                  
                  <div className="ml-auto flex items-center justify-center">
                    <CheckCircle className={`w-6 h-6 transition-all duration-500 ${
                      task.completed 
                        ? 'text-green-500 opacity-100 scale-110' 
                        : 'text-gray-500 opacity-0 group-hover:opacity-100 group-hover:text-green-400 scale-100'
                    }`} />
                  </div>
                </div>
              ))}
              
              <Reveal delay={400} direction="up">
                <button className="w-full mt-2 py-4 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all flex items-center justify-center gap-2 hover-target">
                  Přidat vlastní úkol +
                </button>
              </Reveal>
            </div>
          </section>

          {/* --- СЕКЦИЯ 5: БЫСТРЫЕ ДЕЙСТВИЯ --- */}
          <section>
            <Reveal direction="left">
              <h2 className="text-3xl font-heading mb-8">Rychlé akce</h2>
            </Reveal>
            
            <div className="grid grid-cols-2 gap-4 h-[calc(100%-4rem)]">
              {/* Верхняя левая */}
              <Reveal delay={100} direction="left" className="h-full">
                <SpotlightButton glowColor="rgba(124, 111, 247, 0.8)" className="hover:bg-[#7C6FF7]/5">
                  <div className="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center group-hover:scale-110 group-hover:bg-[#7C6FF7]/20 transition-all">
                    <FileText className="text-gray-300 group-hover:text-[#7C6FF7]" />
                  </div>
                  <span className="font-medium">+ Nová poznámka</span>
                </SpotlightButton>
              </Reveal>

              {/* Верхняя правая */}
              <Reveal delay={200} direction="right" className="h-full">
                <SpotlightButton glowColor="rgba(77, 184, 255, 0.8)" className="hover:bg-[#4DB8FF]/5">
                  <div className="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center group-hover:scale-110 group-hover:bg-[#4DB8FF]/20 transition-all">
                    <BookOpen className="text-gray-300 group-hover:text-[#4DB8FF]" />
                  </div>
                  <span className="font-medium">+ Nová kartička</span>
                </SpotlightButton>
              </Reveal>

              {/* Нижняя левая */}
              <Reveal delay={300} direction="up" className="h-full">
                <SpotlightButton glowColor="rgba(34, 197, 94, 0.8)" className="hover:bg-green-500/5">
                  <div className="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center group-hover:scale-110 group-hover:bg-green-500/20 transition-all">
                    <PenTool className="text-gray-300 group-hover:text-green-400" />
                  </div>
                  <span className="font-medium">+ Nový test</span>
                </SpotlightButton>
              </Reveal>

              {/* Нижняя правая */}
              <Reveal delay={400} direction="up" className="h-full">
                <SpotlightButton glowColor="rgba(255, 255, 255, 0.6)" className="hover:bg-white/5">
                  <div className="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center group-hover:scale-110 transition-all">
                    <Folder className="text-gray-300 group-hover:text-white" />
                  </div>
                  <span className="font-medium">Procházet kurzy</span>
                </SpotlightButton>
              </Reveal>
            </div>
          </section>

        </div>
        
        {/* Footer */}
        <footer className="mt-10 pt-8 pb-12 flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-gray-500 hover-target cursor-default">
          <div className="flex items-center gap-3">
            <div className="relative flex items-center justify-center w-3 h-3">
              <span className="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"></span>
              <span className="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </div>
            <span className="font-medium text-gray-400">All systems operational</span>
          </div>
          <div className="flex gap-8">
            <a href="#" className="hover:text-white transition-colors hover-target">Podpora</a>
            <a href="#" className="hover:text-white transition-colors hover-target">Twitter (X)</a>
            <a href="#" className="hover:text-white transition-colors hover-target">Discord</a>
          </div>
          <div className="font-medium">Lapis v.1.0.42</div>
        </footer>
      </div>
    </div>
  );
}
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<PremiumDashboard />);
  </script>
</body>
</html>
