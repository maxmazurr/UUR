                          </div>
                        </div>
                      </div>

                      {/* График активности */}
                      <div className="flex-1 glass-card rounded-xl border border-white/10 p-4 flex items-end gap-3 justify-between mt-2">
                        {[30, 60, 40, 85, 50, 75, 45].map((h, i) => (
                          <div key={i} className="flex-1 rounded-t-sm opacity-80" style={{ height: `${h}%`, backgroundImage: 'linear-gradient(to top, var(--orb-color-1), var(--orb-color-2))' }}></div>
                        ))}
                      </div>
                      
                      {/* Мягкое внутреннее свечение мокапа */}
                      <div className="absolute -top-10 -right-10 w-32 h-32 blur-3xl rounded-full" style={{ backgroundColor: 'rgba(var(--orb-color-2-rgb), 0.2)' }}></div>
                    </div>
                  </div>
                </div>
                
                {/* Левитирующие бэйджики вокруг мокапа */}
                <div style={{ position: 'absolute', right: -20, top: 60, animation: 'float2 7s ease-in-out infinite' }}>
                  <div className="glass-card" style={{ background: 'rgba(10,11,16,0.9)', padding: '10px 16px', borderRadius: 14, display: 'flex', alignItems: 'center', gap: 10, border: '1px solid rgba(var(--orb-color-1-rgb),0.3)', boxShadow: '0 10px 30px rgba(var(--orb-color-1-rgb),0.2)', backdropFilter: 'blur(24px)' }}>
                    <CheckCircle size={16} style={{ color: 'var(--orb-color-1)' }} />
                    <span style={{ fontSize: 12, fontWeight: 600 }}>Smart Repetition</span>
                  </div>
                </div>
                <div style={{ position: 'absolute', left: -30, bottom: 80, animation: 'float1 6s ease-in-out infinite' }}>
                  <div className="glass-card" style={{ background: 'rgba(10,11,16,0.9)', padding: '10px 16px', borderRadius: 14, display: 'flex', alignItems: 'center', gap: 10, border: '1px solid rgba(var(--orb-color-2-rgb),0.3)', boxShadow: '0 10px 30px rgba(var(--orb-color-2-rgb),0.2)', backdropFilter: 'blur(24px)' }}>
                    <Zap size={16} style={{ color: 'var(--orb-color-2)' }} />
                    <span style={{ fontSize: 12, fontWeight: 600 }}>Chytrý asistent</span>
                  </div>
                </div>
              </Reveal>
            </div>
          </div>
        </section>

        {/* --- СЕКЦИЯ 1.5: БЫСТРЫЙ ПОИСК (STATIC SHOWCASE) --- */}
        <section className="relative z-50 pt-24 pb-[450px] px-4">
          <Reveal delay={200} direction="up" className="max-w-3xl mx-auto relative">
            
            <div className="text-center mb-12">
              <div className="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-gray-400 mb-4 hover-target cursor-default">
                <Search className="w-3.5 h-3.5" /> Bleskové hledání
              </div>
              <h2 className="text-4xl md:text-5xl font-heading mb-4">Chytré vyhledávání</h2>
              <p className="text-gray-400 text-lg">Najdi jakoukoliv kartičku, poznámku nebo kurz rychlostí blesku. <br className="hidden md:block"/> Stačí zmáčknout <kbd className="font-mono bg-white/10 px-2 py-0.5 rounded text-sm text-white">⌘K</kbd> a začít psát.</p>
            </div>
            
            {/* Поисковая строка (Статичный мокап) */}
            <div className="relative z-20 hover-target cursor-text" style={{ filter: 'drop-shadow(0 0 40px rgba(var(--orb-color-1-rgb), 0.2))' }}>
              <Search className="absolute left-6 top-1/2 -translate-y-1/2 w-6 h-6" style={{ color: 'var(--orb-color-1)' }} />
              <div className="w-full glass-card border bg-[#0F1117]/90 rounded-2xl py-6 pl-16 pr-20 text-xl text-white shadow-2xl flex items-center" style={{ borderColor: 'rgba(var(--orb-color-1-rgb), 0.5)' }}>
                <span>bio</span>
                <span className="w-[2px] h-6 ml-1 animate-pulse" style={{ backgroundColor: 'var(--orb-color-1)' }}></span>
              </div>
              <div className="absolute right-6 top-1/2 -translate-y-1/2 flex items-center gap-1 px-3 py-1.5 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-400 font-mono">
                <Command className="w-3.5 h-3.5" /> K
              </div>
            </div>

            {/* Выпадающее окно с результатами (Всегда открыто для презентации) */}
            <div className="absolute top-[calc(100%+16px)] left-0 right-0 glass-card bg-[#0F1117]/95 rounded-2xl border border-white/10 overflow-hidden shadow-2xl z-10">
              <div className="p-4">
                <div className="flex flex-col gap-5">
                  
                  {/* Группа 1: Папки и Темы */}
                  <div>
                    <div className="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-2">Složky a Témata</div>
                    <div className="flex flex-col gap-1">
                      <div className="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5 cursor-default hover-target group">
                        <Folder className="w-5 h-5" style={{ color: 'var(--orb-color-1)' }} />
                        <div className="font-medium text-white">
                          <span className="px-1 rounded" style={{ color: 'var(--orb-color-1)', backgroundColor: 'rgba(var(--orb-color-1-rgb), 0.2)' }}>Bio</span>logie 101
                        </div>
