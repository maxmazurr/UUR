                      </div>
                      <div className="flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 cursor-default transition-colors hover-target group">
                        <Folder className="w-5 h-5 text-gray-400 transition-colors" />
                        <div className="font-medium text-white">
                          <span className="px-1 rounded" style={{ color: 'var(--orb-color-1)', backgroundColor: 'rgba(var(--orb-color-1-rgb), 0.2)' }}>Bio</span>logie — Ekologie
                        </div>
                        <div className="ml-auto text-xs text-gray-400 border border-white/10 px-2 py-1 rounded">Složka</div>
                      </div>
                      <div className="flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 cursor-default transition-colors hover-target group">
                        <Folder className="w-5 h-5 text-gray-400 transition-colors" />
                        <div className="font-medium text-white">
                          <span className="px-1 rounded" style={{ color: 'var(--orb-color-1)', backgroundColor: 'rgba(var(--orb-color-1-rgb), 0.2)' }}>Bio</span>logie — Vizualizace
                        </div>
                        <div className="ml-auto text-xs text-gray-400 border border-white/10 px-2 py-1 rounded">Složka</div>
                      </div>
                    </div>
                  </div>

                  {/* Группа 2: Карточки, Тесты и Заметки */}
                  <div>
