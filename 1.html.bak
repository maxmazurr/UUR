                    <div className="flex flex-col gap-1">
                      {/* Карточка */}
                      <div className="flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 cursor-default transition-colors hover-target group">
                        <Layers className="w-5 h-5" style={{ color: 'var(--orb-color-2)' }} />
                        <div className="font-medium text-white">
                          Definice: <span className="px-1 rounded" style={{ color: 'var(--orb-color-2)', backgroundColor: 'rgba(var(--orb-color-2-rgb), 0.2)' }}>bio</span>sféra
                        </div>
                        <div className="ml-auto flex flex-col items-end">
                          <span className="text-xs text-white">Věda o životě</span>
