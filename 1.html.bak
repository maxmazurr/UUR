                          Závěrečný test: <span className="text-yellow-400 bg-yellow-400/20 px-1 rounded">Bio</span>logie buněk
                        </div>
                        <div className="ml-auto text-xs text-gray-400 border border-white/10 px-2 py-1 rounded">Test</div>
                      </div>
                      {/* Заметка */}
                      <div className="flex items-center gap-3 p-3 rounded-xl hover:bg-white/5 cursor-default transition-colors hover-target group">
                        <FileText className="w-5 h-5 text-green-400" />
                        <div className="font-medium text-white">
                          Poznámky k zápočtu (<span className="text-green-400 bg-green-400/20 px-1 rounded">bio</span>logie)
                        </div>
                        <div className="ml-auto text-xs text-gray-400 border border-white/10 px-2 py-1 rounded">Poznámka</div>
                      </div>
