                        <div className="h-10 w-10 rounded-full border flex items-center justify-center text-lg" style={{ backgroundColor: 'rgba(var(--orb-color-1-rgb), 0.2)', borderColor: 'rgba(var(--orb-color-1-rgb), 0.5)', boxShadow: '0 0 15px rgba(var(--orb-color-1-rgb), 0.3)' }}>👨‍🎓</div>
                      </div>
                      
                      {/* Сетка карточек */}
                      <div className="grid grid-cols-2 gap-3">
