                    <div className="w-1/4 border-r border-white/10 bg-white/5 p-4 flex flex-col gap-3">
                      <div className="h-6 w-full rounded flex items-center px-2 border-l-2" style={{ background: 'linear-gradient(to right, rgba(var(--orb-color-1-rgb), 0.2), transparent)', borderColor: 'var(--orb-color-1)' }}></div>
                      <div className="h-5 w-3/4 bg-white/5 rounded mt-2"></div>
                      <div className="h-5 w-full bg-white/5 rounded"></div>
                      <div className="h-5 w-2/3 bg-white/5 rounded"></div>
                    </div>
                    
                    {/* Основной контент */}
                    <div className="flex-1 p-5 flex flex-col gap-4 relative overflow-hidden">
