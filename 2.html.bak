<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StudyFlow Dashboard</title>
  
  <!-- Tailwind CSS via CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- React and ReactDOM -->
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  
  <!-- Babel for parsing JSX -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <!-- Lucide icons -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #0F1117;
      color: #F0F2F8;
    }
    #root {
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useRef, useMemo, useCallback } = React;

    // --- ИКОНКИ ---
    const Icon = ({ name, size = 24, className = '', style = {} }) => {
      const iconRef = useRef(null);
      useEffect(() => {
        if (iconRef.current && window.lucide) {
          const kebabName = name.replace(/([a-z0-9])([A-Z])/g, '$1-$2').toLowerCase();
          iconRef.current.innerHTML = `<i data-lucide="${kebabName}"></i>`;
          window.lucide.createIcons({ root: iconRef.current });
          const svg = iconRef.current.querySelector('svg');
          if (svg) {
            svg.setAttribute('width', size);
            svg.setAttribute('height', size);
            if (className) {
              // preserve existing classes from lucide (like lucide-icon)
              svg.setAttribute('class', svg.getAttribute('class') + ' ' + className);
            }
          }
        }
      }, [name, size, className]);
      return <span ref={iconRef} style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', width: size, height: size, ...style }} />;
    };

    // Алиасы для нужных иконок
    const Menu = (p) => <Icon name="Menu" {...p} />;
    const Search = (p) => <Icon name="Search" {...p} />;
    const Bell = (p) => <Icon name="Bell" {...p} />;
    const Home = (p) => <Icon name="Home" {...p} />;
    const FileText = (p) => <Icon name="FileText" {...p} />;
    const Layers = (p) => <Icon name="Layers" {...p} />;
    const CheckSquare = (p) => <Icon name="CheckSquare" {...p} />;
    const BarChart2 = (p) => <Icon name="BarChart2" {...p} />;
    const Network = (p) => <Icon name="Network" {...p} />;
    const Settings = (p) => <Icon name="Settings" {...p} />;
    const HelpCircle = (p) => <Icon name="HelpCircle" {...p} />;
    const Plus = (p) => <Icon name="Plus" {...p} />;
    const Folder = (p) => <Icon name="Folder" {...p} />;
    const Play = (p) => <Icon name="Play" {...p} />;
    const ChevronRight = (p) => <Icon name="ChevronRight" {...p} />;
    const ChevronLeft = (p) => <Icon name="ChevronLeft" {...p} />;
    const Flame = (p) => <Icon name="Flame" {...p} />;
    const Target = (p) => <Icon name="Target" {...p} />;
    const Lightbulb = (p) => <Icon name="Lightbulb" {...p} />;
    const ArrowRight = (p) => <Icon name="ArrowRight" {...p} />;
    const Activity = (p) => <Icon name="Activity" {...p} />;
    const Award = (p) => <Icon name="Award" {...p} />;
    const BookOpen = (p) => <Icon name="BookOpen" {...p} />;
    const Clock = (p) => <Icon name="Clock" {...p} />;
    const Frown = (p) => <Icon name="Frown" {...p} />;
    const Smile = (p) => <Icon name="Smile" {...p} />;
    const Command = (p) => <Icon name="Command" {...p} />;

    // --- ХУКИ И АНИМАЦИИ ---

    function useOnScreen(ref, rootMargin = '0px') {
      const [isIntersecting, setIntersecting] = useState(false);
      useEffect(() => {
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              setIntersecting(true);
              observer.disconnect();
            }
          },
          { rootMargin, threshold: 0.1 }
        );
        if (ref.current) observer.observe(ref.current);
        return () => observer.disconnect();
      }, [ref, rootMargin]);
      return isIntersecting;
    }

    const CountUp = ({ end, duration = 1500, suffix = "" }) => {
      const [count, setCount] = useState(0);
      const ref = useRef(null);
      const isVisible = useOnScreen(ref);

      useEffect(() => {
        if (!isVisible) return;
        let startTimestamp = null;
        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          const easeProgress = 1 - Math.pow(1 - progress, 4);
          setCount(Math.floor(easeProgress * end));
          if (progress < 1) {
            window.requestAnimationFrame(step);
          }
        };
        window.requestAnimationFrame(step);
      }, [end, duration, isVisible]);

      return <span ref={ref} className="font-mono">{count}{suffix}</span>;
    };

    const FadeUp = ({ children, delay = 0, className = "" }) => {
      const ref = useRef(null);
      const isVisible = useOnScreen(ref);
      return (
        <div
          ref={ref}
          className={`transition-all duration-700 ease-out transform ${
            isVisible ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'
          } ${className}`}
          style={{ transitionDelay: `${delay}ms` }}
        >
          {children}
        </div>
      );
    };

    // --- ГЛАВНЫЙ КОМПОНЕНТ ---

    // Данные для поиска
    const ALL_SEARCH_ITEMS = [
      { type: 'notes', icon: 'FileText', color: '#4F9CF9', label: 'Matice - přednáška 1' },
      { type: 'notes', icon: 'FileText', color: '#4F9CF9', label: 'Vektory - shrnutí' },
      { type: 'notes', icon: 'FileText', color: '#4ADE80', label: 'React hooks - poznámky' },
      { type: 'cards', icon: 'Layers', color: '#7C6FF7', label: 'Definice determinantu' },
      { type: 'cards', icon: 'Layers', color: '#7C6FF7', label: 'Derivace funkce' },
      { type: 'cards', icon: 'Layers', color: '#7C6FF7', label: 'Pythagorova věta' },
      { type: 'tests', icon: 'CheckSquare', color: '#4ADE80', label: 'Lineární algebra - test 1' },
      { type: 'courses', icon: 'BookOpen', color: '#FB923C', label: 'Dějepis - 1. světová válka' },
    ];

    function Dashboard() {
      const [sidebarOpen, setSidebarOpen] = useState(true);
      const [searchFocused, setSearchFocused] = useState(false);
      const [searchQuery, setSearchQuery] = useState("");
      const [greeting, setGreeting] = useState("Dobré ráno");
      const [tipFlipped, setTipFlipped] = useState(false);
      const [activeNav, setActiveNav] = useState('Dashboard');
      const [completedCards, setCompletedCards] = useState([]);
      const [notifOpen, setNotifOpen] = useState(false);
      const searchInputRef = useRef(null);

      const TOTAL_DAILY = 20;
      const BASE_DONE = 8;
      const currentDone = BASE_DONE + completedCards.length;
      const dailyPercent = Math.min(Math.round((currentDone / TOTAL_DAILY) * 100), 100);

      useEffect(() => {
        const hour = new Date().getHours();
        if (hour < 12) setGreeting("Dobré ráno");
        else if (hour < 18) setGreeting("Dobré odpoledne");
        else setGreeting("Dobrý večer");
      }, []);

      // ⌘K / Ctrl+K shortcut
      useEffect(() => {
        const handler = (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            searchInputRef.current && searchInputRef.current.focus();
          }
          if (e.key === 'Escape') {
            setSearchFocused(false);
            setNotifOpen(false);
            searchInputRef.current && searchInputRef.current.blur();
          }
        };
        window.addEventListener('keydown', handler);
        return () => window.removeEventListener('keydown', handler);
      }, []);

      // Поиск
      const filteredItems = useMemo(() => {
        if (!searchQuery.trim()) return ALL_SEARCH_ITEMS;
        const q = searchQuery.toLowerCase();
        return ALL_SEARCH_ITEMS.filter(item => item.label.toLowerCase().includes(q));
      }, [searchQuery]);

      const toggleCard = useCallback((title) => {
        setCompletedCards(prev => prev.includes(title) ? prev.filter(t => t !== title) : [...prev, title]);
      }, []);

      // Горизонтальный скролл
      const scrollRef = useRef(null);
      const scrollLeft = () => {
        if (scrollRef.current) scrollRef.current.scrollBy({ left: -300, behavior: 'smooth' });
      };
      const scrollRight = () => {
        if (scrollRef.current) scrollRef.current.scrollBy({ left: 300, behavior: 'smooth' });
      };

      // Data pro kompaktní heatmapu (14 týdnů, 7 dní)
      const heatmapData = useMemo(() => Array.from({ length: 14 }, () => 
        Array.from({ length: 7 }, () => Math.random() > 0.5 ? Math.floor(Math.random() * 4 + 1) : 0)
      ), []);

      return (
        <div className="flex h-screen bg-app-bg text-app-text overflow-hidden font-body relative">
          
          {/* --- СТИЛИ --- */}
          <style>{`
            @import url('https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@800,500,700,400&display=swap');
            @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap');

            :root {
              --bg-primary: #0F1117;
              --bg-secondary: #161B27;
              --bg-tertiary: #1E2536;
              --accent-primary: #7C6FF7;
              --accent-blue: #4F9CF9;
              --accent-green: #4ADE80;
              --accent-orange: #FB923C;
              --accent-red: #F87171;
              --text-primary: #F0F2F8;
              --text-secondary: #8891AA;
              --text-muted: #4A5270;
              --glass-bg: rgba(30, 37, 54, 0.6);
              --glass-border: rgba(124, 111, 247, 0.15);
            }

            .bg-app-bg { background-color: var(--bg-primary); }
            .bg-app-sec { background-color: var(--bg-secondary); }
            .bg-app-ter { background-color: var(--bg-tertiary); }
            .text-app-text { color: var(--text-primary); }
            .text-app-sec { color: var(--text-secondary); }
            .text-app-muted { color: var(--text-muted); }

            .font-display { font-family: 'Cabinet Grotesk', sans-serif; }
            .font-body { font-family: 'DM Sans', sans-serif; }
            .font-mono { font-family: 'JetBrains Mono', monospace; }

            .glass-panel {
              background: var(--glass-bg);
              border: 1px solid var(--glass-border);
              backdrop-filter: blur(20px);
              -webkit-backdrop-filter: blur(20px);
            }

            .mesh-gradient-bg {
              position: absolute; top: 0; left: 0; right: 0; bottom: 0;
              z-index: 0; overflow: hidden; pointer-events: none;
            }
            .mesh-blob {
              position: absolute; border-radius: 50%; filter: blur(120px);
              animation: blobMovement 8s infinite alternate ease-in-out;
            }
            .blob-1 { width: 50vw; height: 50vw; background: rgba(124, 111, 247, 0.15); top: -20vh; left: -10vw; }
            .blob-2 { width: 40vw; height: 40vw; background: rgba(79, 156, 249, 0.15); top: 10vh; right: -10vw; animation-delay: -3s; }
            .blob-3 { width: 45vw; height: 45vw; background: rgba(74, 222, 128, 0.08); bottom: -10vh; left: 20vw; animation-delay: -5s; }

            @keyframes blobMovement {
              0% { transform: translate(0, 0) scale(1); }
              100% { transform: translate(30px, 40px) scale(1.05); }
            }

            .nav-item.active {
              background: rgba(124, 111, 247, 0.1);
              border-left: 3px solid var(--accent-primary);
            }
            .nav-item:not(.active) { border-left: 3px solid transparent; }
            .nav-item:hover:not(.active) { background: var(--bg-tertiary); }

            .no-scrollbar::-webkit-scrollbar { display: none; }
            .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

            .search-bar { transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1); width: 400px; }
            .search-bar.focused { width: 600px; }

            .float-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
            .float-card:hover { transform: translateY(-8px) rotate(0deg) !important; box-shadow: 0 20px 40px rgba(0,0,0,0.4); z-index: 10; }

            .circular-chart { display: block; margin: 0 auto; max-width: 80%; max-height: 250px; }
            .circle-bg { fill: none; stroke: var(--bg-tertiary); stroke-width: 3.8; }
            .circle { 
              fill: none; stroke-width: 3.8; stroke-linecap: round; 
              animation: progress 1s ease-out forwards;
            }
            @keyframes progress { 0% { stroke-dasharray: 0, 100; } }

            .flip-card-inner {
              transition: transform 0.6s; transform-style: preserve-3d; position: relative; width: 100%; height: 100%;
            }
            .flip-card.flipped .flip-card-inner { transform: rotateY(180deg); }
            .flip-card-front, .flip-card-back {
              position: absolute; width: 100%; height: 100%; backface-visibility: hidden; top: 0; left: 0;
            }
            .flip-card-back { transform: rotateY(180deg); }

            .heat-0 { background: #1E2536; }
            .heat-1 { background: rgba(124, 111, 247, 0.3); }
            .heat-2 { background: rgba(124, 111, 247, 0.6); }
            .heat-3 { background: rgba(124, 111, 247, 0.9); }
            .heat-4 { background: #7C6FF7; }

            @keyframes pulse-shadow {
              0% { box-shadow: 0 0 0 0 rgba(124, 111, 247, 0.4); }
              70% { box-shadow: 0 0 0 10px rgba(124, 111, 247, 0); }
              100% { box-shadow: 0 0 0 0 rgba(124, 111, 247, 0); }
            }
            .btn-pulse { animation: pulse-shadow 2s infinite; }

            .fast-action-tile { transition: all 0.3s ease; }
            .fast-action-tile:hover { transform: scale(1.02); background: var(--bg-tertiary); }
            .fast-action-tile:hover svg { transform: scale(1.1); transition: transform 0.3s ease; }
            
            @keyframes fadeInUp { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
            .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }
          `}</style>

          {/* --- SIDEBAR --- */}
          <div className={`flex flex-col border-r border-white/5 bg-app-sec transition-all duration-300 z-50 ${sidebarOpen ? 'w-[280px]' : 'w-[64px]'}`}>
            
            {/* User / Top */}
            <div className={`p-4 border-b border-white/5 flex flex-col gap-3 overflow-hidden shrink-0 transition-all duration-300 ${sidebarOpen ? 'h-[120px]' : 'h-[72px] items-center justify-center'}`}>
              <div className={`flex items-center ${sidebarOpen ? 'gap-3' : 'justify-center'}`}>
                <div className="w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg bg-gradient-to-tr from-[#7C6FF7] to-[#4F9CF9] text-white shrink-0">
                  JN
                </div>
                {sidebarOpen && (
                  <div className="flex flex-col whitespace-nowrap">
                    <span className="font-semibold text-sm">Jan Novák</span>
                    <span className="text-xs text-app-sec flex items-center gap-1 mt-0.5">
                      <Flame size={12} className="text-[#FB923C]" /> 32 dní v řadě
                    </span>
                  </div>
                )}
              </div>
              {sidebarOpen && (
                <div className="w-full">
                  <div className="flex justify-between text-[10px] text-app-sec mb-1">
                    <span>Dnešní cíl</span>
                    <span>{currentDone}/{TOTAL_DAILY}</span>
                  </div>
                  <div className="h-1.5 w-full bg-app-ter rounded-full overflow-hidden">
                    <div className="h-full bg-[#4ADE80] rounded-full transition-all duration-500" style={{ width: `${dailyPercent}%` }}></div>
                  </div>
                </div>
              )}
            </div>

            {/* Navigation */}
            <div className="flex-1 overflow-y-auto no-scrollbar py-4 px-2 flex flex-col gap-1">
              <NavItem icon={<Home size={20} />} label="Dashboard" active={activeNav === 'Dashboard'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Dashboard')} />
              <NavItem icon={<FileText size={20} />} label="Poznámky" active={activeNav === 'Poznámky'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Poznámky')} />
              <NavItem icon={<Layers size={20} />} label="Kartičky" badge="12" active={activeNav === 'Kartičky'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Kartičky')} />
              <NavItem icon={<CheckSquare size={20} />} label="Testy" active={activeNav === 'Testy'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Testy')} />
              <NavItem icon={<BarChart2 size={20} />} label="Statistiky" active={activeNav === 'Statistiky'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Statistiky')} />
              <NavItem icon={<Network size={20} />} label="Graf znalostí" active={activeNav === 'Graf znalostí'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Graf znalostí')} />
              
              <div className="my-2 border-t border-white/5 mx-2"></div>
              
              <NavItem icon={<Settings size={20} />} label="Nastavení" active={activeNav === 'Nastavení'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('Nastavení')} />
              <NavItem icon={<HelpCircle size={20} />} label="O aplikaci" active={activeNav === 'O aplikaci'} sidebarOpen={sidebarOpen} onClick={() => setActiveNav('O aplikaci')} />

              {/* TreeView (Mock) */}
              {sidebarOpen && (
                <div className="mt-6 px-2">
                  <div className="flex justify-between items-center text-xs text-app-muted uppercase font-bold tracking-wider mb-2 px-2">
                    <span>Moje kurzy</span>
                    <button className="hover:text-white transition-colors"><Plus size={14}/></button>
                  </div>
                  <div className="flex flex-col gap-1 text-sm cursor-default">
                    <TreeItem title="Lineární algebra" color="#4F9CF9" open cards={16} />
                    <TreeItem title="Programování" color="#4ADE80" open cards={0} />
                    <TreeItem title="Dějepis" color="#FB923C" open cards={0} />
                  </div>
                </div>
              )}
            </div>
          </div>

          {/* --- MAIN CONTENT --- */}
          <div className="flex-1 flex flex-col h-screen relative overflow-hidden">
            
            {/* Mesh Background */}
            <div className="mesh-gradient-bg">
              <div className="mesh-blob blob-1"></div>
              <div className="mesh-blob blob-2"></div>
              <div className="mesh-blob blob-3"></div>
            </div>

            {/* --- TOPBAR --- */}
            <div className="h-[64px] sticky top-0 z-[100] backdrop-blur-xl bg-app-bg/80 border-b border-white/5 flex items-center px-4 justify-between shrink-0">
              <div className="flex items-center gap-4">
                <button onClick={() => setSidebarOpen(!sidebarOpen)} className="p-2 text-app-sec hover:text-white transition-colors rounded-lg hover:bg-white/5">
                  <Menu size={20} />
                </button>
                <div className="text-xl font-display font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#7C6FF7] to-[#4F9CF9]">
                  StudyFlow
                </div>
                <div className="h-6 w-[1px] bg-white/10 mx-2 hidden sm:block"></div>
              </div>

              {/* Search */}
              <div className="relative group flex items-center justify-center flex-1 max-w-2xl px-4 hidden md:flex">
                <div className={`relative search-bar ${searchFocused ? 'focused' : ''}`}>
                  <div className="absolute left-3 top-1/2 -translate-y-1/2 text-app-muted"><Search size={18} /></div>
                  <input 
                    ref={searchInputRef}
                    type="text" 
                    placeholder="Hledat poznámky, kartičky, kurzy..." 
                    className="w-full bg-app-ter/50 border border-white/10 rounded-xl py-2 pl-10 pr-12 text-sm focus:outline-none focus:border-[#7C6FF7]/50 focus:bg-app-sec transition-all placeholder-app-muted text-white"
                    value={searchQuery}
                    onFocus={() => setSearchFocused(true)}
                    onBlur={() => { setTimeout(() => setSearchFocused(false), 200); }}
                    onChange={(e) => setSearchQuery(e.target.value)}
                  />
                  <div className="absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-1 text-[10px] bg-white/5 px-1.5 py-0.5 rounded text-app-muted border border-white/5 font-mono">
                    ⌘K
                  </div>
                </div>

                {/* Блок результатов поиска */}
                {searchFocused && (
                  <div className="absolute top-12 w-full max-w-[600px] bg-app-sec border border-white/10 rounded-xl shadow-2xl overflow-hidden z-[101] backdrop-blur-3xl animate-fade-in-up">
                    {filteredItems.length === 0 ? (
                      <div className="p-4 text-sm text-app-muted text-center">Žádné výsledky pro "{searchQuery}"</div>
                    ) : (
                      <React.Fragment>
                        {['notes','cards','tests','courses'].map(type => {
                          const items = filteredItems.filter(i => i.type === type);
                          if (items.length === 0) return null;
                          const labels = { notes: '📄 Poznámky', cards: '🃏 Kartičky', tests: '✅ Testy', courses: '📚 Kurzy' };
                          return (
                            <React.Fragment key={type}>
                              <div className="p-2 text-xs font-medium text-app-muted border-b border-white/5">{labels[type]}</div>
                              {items.map((item, idx) => (
                                <div key={idx} className="p-2 hover:bg-white/5 cursor-pointer flex gap-3 items-center">
                                  <Icon name={item.icon} size={16} style={{ color: item.color }} />
                                  <span className="text-sm">{item.label}</span>
                                </div>
                              ))}
                            </React.Fragment>
                          );
                        })}
                      </React.Fragment>
                    )}
                  </div>
                )}
              </div>

              <div className="flex items-center gap-4">
                <button className="relative p-2 text-app-sec hover:text-white transition-colors rounded-lg hover:bg-white/5 md:hidden">
                  <Search size={20} />
                </button>
                <div className="relative">
                  <button onClick={() => setNotifOpen(!notifOpen)} className="relative p-2 text-app-sec hover:text-white transition-colors rounded-lg hover:bg-white/5">
                    <Bell size={20} />
                    <span className="absolute top-1.5 right-1.5 w-2 h-2 bg-[#F87171] rounded-full border-2 border-app-bg"></span>
                  </button>
                  {notifOpen && (
                    <div className="absolute right-0 top-12 w-[300px] bg-app-sec border border-white/10 rounded-xl shadow-2xl z-[102] animate-fade-in-up overflow-hidden">
                      <div className="p-3 border-b border-white/5 text-sm font-medium">Oznámení</div>
                      <div className="p-3 hover:bg-white/5 cursor-pointer border-b border-white/5 flex gap-3 items-start">
                        <div className="w-2 h-2 mt-1.5 rounded-full bg-[#4F9CF9] shrink-0"></div>
                        <div><div className="text-sm">Nový test k dispozici</div><div className="text-[10px] text-app-muted mt-0.5">Lineární algebra - před 2h</div></div>
                      </div>
                      <div className="p-3 hover:bg-white/5 cursor-pointer border-b border-white/5 flex gap-3 items-start">
                        <div className="w-2 h-2 mt-1.5 rounded-full bg-[#4ADE80] shrink-0"></div>
                        <div><div className="text-sm">Série 30 dní!</div><div className="text-[10px] text-app-muted mt-0.5">Gratulujeme! - před 1d</div></div>
                      </div>
                      <div className="p-3 hover:bg-white/5 cursor-pointer flex gap-3 items-start">
                        <div className="w-2 h-2 mt-1.5 rounded-full bg-[#FB923C] shrink-0"></div>
                        <div><div className="text-sm">5 kartiček expiruje</div><div className="text-[10px] text-app-muted mt-0.5">Dějepis - před 3d</div></div>
                      </div>
                    </div>
                  )}
                </div>
                <div className="flex items-center gap-2 cursor-pointer hover:bg-white/5 p-1 rounded-full pr-3 transition-colors border border-transparent hover:border-white/5">
                  <div className="w-8 h-8 rounded-full bg-gradient-to-tr from-[#7C6FF7] to-[#4F9CF9] flex items-center justify-center font-bold text-xs text-white">JN</div>
                </div>
              </div>
            </div>

            {/* --- MAIN SCROLL AREA --- */}
            <div className="flex-1 overflow-y-auto no-scrollbar pb-24 relative z-10 px-4 sm:px-6 md:px-12 py-8">
              <div className="max-w-[1200px] mx-auto flex flex-col gap-10">
                
                {/* СЕКЦИЯ 1: COMPACT HERO + INLINE STATS */}
                <section className="relative z-20">
                  <div className="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                    {/* Left: Greeting + CTA */}
                    <div className="flex-1">
                      <FadeUp delay={100}>
                        <h1 className="text-3xl md:text-4xl font-display font-medium mb-2 tracking-tight">
                          {greeting}, Jan 👋
                        </h1>
                      </FadeUp>
                      <FadeUp delay={150}>
                        <p className="text-lg text-app-sec mb-5 max-w-lg leading-relaxed">
                          Dnes tě čeká <strong className="text-white">{TOTAL_DAILY - currentDone} kartiček</strong> a <strong className="text-white">2 nedokončené testy</strong>.
                        </p>
                      </FadeUp>
                      <FadeUp delay={200} className="flex flex-wrap gap-3">
                        <button className="btn-pulse bg-gradient-to-r from-[#7C6FF7] to-[#4F9CF9] text-white px-5 py-2.5 rounded-xl font-medium flex items-center gap-2 hover:brightness-110 transition-all text-sm">
                          <Play size={16} className="fill-current" /> Začít opakování
                        </button>
                        <button className="glass-panel text-white px-5 py-2.5 rounded-xl font-medium flex items-center gap-2 hover:bg-white/5 transition-all text-sm">
                          <FileText size={16} /> Nová poznámka
                        </button>
                      </FadeUp>
                    </div>
                  </div>
                </section>

                {/* СЕКЦИЯ 2: Streak, Dnevní cíl, Tip — key stats */}
                <section className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  
                  {/* Dnešní cíl — moved first */}
                  <FadeUp delay={100} className="bg-app-sec border border-white/5 rounded-2xl p-6 relative overflow-hidden flex flex-col items-center justify-center">
                    <div className="absolute top-6 left-6 text-sm font-medium text-app-sec">Dnešní cíl</div>
                    
                    <div className="relative w-32 h-32 mt-4">
                      <svg viewBox="0 0 36 36" className="circular-chart w-full h-full">
                        <path className="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <path className="circle" stroke="#7C6FF7" strokeDasharray={`${dailyPercent}, 100`} d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" style={{ transition: 'stroke-dasharray 0.6s ease' }} />
                      </svg>
                      <div className="absolute inset-0 flex flex-col items-center justify-center">
                        <span className="text-2xl font-mono font-bold leading-none">{currentDone}<span className="text-app-sec text-sm leading-none">/{TOTAL_DAILY}</span></span>
                        <span className="text-[10px] text-app-sec">karet</span>
                      </div>
                    </div>
                    <div className="w-full mt-4 bg-app-ter rounded-lg px-4 py-2 flex justify-between items-center group cursor-pointer hover:bg-white/5 transition-colors">
                      <div className="text-xs">Zbývá: <strong className="text-white">{TOTAL_DAILY - currentDone} karet</strong></div>
                      <ArrowRight size={14} className="text-[#7C6FF7] group-hover:translate-x-1 transition-transform" />
                    </div>
                  </FadeUp>

                  {/* Streak */}
                  <FadeUp delay={150} className="bg-app-sec border border-white/5 rounded-2xl p-6 flex flex-col justify-between">
                    <div className="flex justify-between items-start mb-6">
                      <div>
                        <div className="text-sm font-medium text-app-sec mb-1 flex items-center gap-2">Tvá série <Flame size={16} className="text-[#FB923C]"/></div>
                        <div className="text-4xl font-mono font-bold text-white">32 <span className="text-xl text-app-sec font-body font-medium">dní</span></div>
                      </div>
                      <div className="bg-[#FB923C]/10 text-[#FB923C] text-xs px-2 py-1 rounded font-medium border border-[#FB923C]/20 shrink-0">Nejdelší: 45</div>
                    </div>
                    <div>
                      <div className="text-xs text-app-muted mb-2 font-medium uppercase tracking-wider">Tento týden</div>
                      <div className="flex justify-between items-center">
                        {['Po','Út','St','Čt','Pá','So','Ne'].map((d, i) => (
                          <div key={i} className="flex flex-col items-center gap-1.5">
                            <span className="text-[10px] text-app-muted">{d}</span>
                            <div className={`w-6 h-6 rounded-full flex items-center justify-center ${i < 4 ? 'bg-[#4ADE80]/20 text-[#4ADE80]' : i === 4 ? 'bg-[#FB923C]/20 text-[#FB923C]' : 'bg-app-ter text-app-sec'}`}>
                              {i < 4 ? <CheckSquare size={12}/> : i === 4 ? <Flame size={12}/> : ''}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </FadeUp>

                  {/* Tip dne (Flip Card) */}
                  <FadeUp delay={200} className="relative h-full min-h-[220px] md:col-span-2 lg:col-span-1" style={{ perspective: '1000px' }}>
                    <div className={`flip-card w-full h-full ${tipFlipped ? 'flipped' : ''}`} onClick={() => !tipFlipped && setTipFlipped(true)}>
                      <div className="flip-card-inner">
                        {/* Front */}
                        <div className="flip-card-front bg-gradient-to-br from-app-sec to-app-ter border border-white/5 rounded-2xl p-6 flex flex-col cursor-pointer hover:border-white/10 transition-colors">
                          <div className="flex items-center gap-2 text-[#4F9CF9] text-sm font-medium mb-4"><Lightbulb size={16}/> Tip dne</div>
                          <div className="flex-1 flex items-center justify-center text-center">
                            <p className="font-display text-lg font-medium leading-tight">Co je to derivace funkce?</p>
                          </div>
                          <div className="text-center text-xs text-app-muted mt-4 p-2 bg-app-bg/50 rounded-lg">
                            Klikni pro zobrazení odpovědi
                          </div>
                        </div>
                        {/* Back */}
                        <div className="flip-card-back bg-gradient-to-br from-[#1A2033] to-[#121624] border border-[#7C6FF7]/30 rounded-2xl p-6 flex flex-col justify-between">
                          <div className="flex items-center gap-2 text-[#4F9CF9] text-sm font-medium mb-2"><Lightbulb size={16}/> Odpověď</div>
                          <p className="text-sm text-app-text leading-relaxed px-1">
                            Derivace udává okamžitou rychlost změny funkce. Geometricky odpovídá směrnici tečny ke grafu funkce v daném bodě.
                          </p>
                          <div className="flex gap-2 mt-4">
                            <button className="flex-1 py-1.5 rounded bg-[#F87171]/10 text-[#F87171] hover:bg-[#F87171]/20 transition-colors text-xs font-medium flex gap-1 justify-center items-center" onClick={(e) => { e.stopPropagation(); setTipFlipped(false); }}><Frown size={14}/> Nevím</button>
                            <button className="flex-1 py-1.5 rounded bg-[#4ADE80]/10 text-[#4ADE80] hover:bg-[#4ADE80]/20 transition-colors text-xs font-medium flex gap-1 justify-center items-center" onClick={(e) => { e.stopPropagation(); setTipFlipped(false); }}><Smile size={14}/> Znám</button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </FadeUp>

                </section>

                {/* СЕКЦИЯ 3: Activity heatmap */}
                <section>
                  <FadeUp className="bg-app-sec border border-white/5 rounded-2xl p-5 flex flex-col md:flex-row gap-6 relative overflow-hidden items-center md:items-stretch shadow-sm">
                    {/* Left: Stats */}
                    <div className="flex-1 w-full flex flex-col justify-center">
                      <div className="flex items-center gap-2 mb-4">
                        <div className="w-8 h-8 rounded-lg bg-[#4F9CF9]/10 text-[#4F9CF9] flex items-center justify-center">
                          <Activity size={18} />
                        </div>
                        <h2 className="text-lg font-display font-medium">Tvoje aktivita</h2>
                      </div>
                      
                      <div className="flex flex-wrap gap-3 mb-5">
                        <div className="bg-app-bg/50 px-4 py-3 rounded-xl border border-white/5 flex-1 min-w-[130px]">
                          <div className="text-[10px] text-app-muted uppercase tracking-wider mb-1 font-medium">Karet tento týden</div>
                          <div className="text-2xl font-mono font-bold text-white flex items-center gap-2">
                            248 <span className="text-xs text-[#4ADE80] font-sans font-medium flex items-center bg-[#4ADE80]/10 px-1.5 py-0.5 rounded leading-none">↑ 12%</span>
                          </div>
                        </div>
                        <div className="bg-app-bg/50 px-4 py-3 rounded-xl border border-white/5 flex-1 min-w-[130px]">
                          <div className="text-[10px] text-app-muted uppercase tracking-wider mb-1 font-medium">Čas učení</div>
                          <div className="text-2xl font-mono font-bold text-white flex items-end gap-2 leading-none">
                            4h 20m <span className="text-xs text-app-muted font-sans font-medium mb-0.5">dnes 45m</span>
                          </div>
                        </div>
                      </div>
                      
                      <div className="flex flex-wrap gap-2 text-[10px]">
                        <div className="px-2.5 py-1.5 bg-[#4ADE80]/10 text-[#4ADE80] border border-[#4ADE80]/20 rounded-lg flex items-center gap-1.5 font-medium"><Award size={12}/> Týden v řadě <span className="text-white ml-0.5">✓</span></div>
                        <div className="px-2.5 py-1.5 bg-[#7C6FF7]/10 text-[#7C6FF7] border border-[#7C6FF7]/20 rounded-lg flex items-center gap-1.5 font-medium"><Layers size={12}/> 100 karet <span className="text-white ml-0.5">✓</span></div>
                        <div className="px-2.5 py-1.5 bg-app-ter text-app-muted border border-white/5 rounded-lg flex items-center gap-1.5 hover:text-white transition-colors cursor-help" title="Dokonči test za méně než 2 minuty"><Clock size={12}/> Speed run <span className="ml-0.5 opacity-50">✗</span></div>
                      </div>
                    </div>
                    
                    {/* Right: Compact Heatmap */}
                    <div className="shrink-0 flex flex-col justify-center bg-app-bg/30 p-5 rounded-xl border border-white/5 w-full md:w-auto">
                      <div className="flex justify-between items-center mb-3 text-[10px] text-app-muted">
                        <span className="font-medium uppercase tracking-wider">Aktivita (14 týdnů)</span>
                        <span className="flex items-center gap-1 text-[9px]">Méně <span className="flex gap-[2px] mx-1"><div className="w-2 h-2 rounded-[1px] bg-[#1E2536]"></div><div className="w-2 h-2 rounded-[1px] bg-[rgba(124,111,247,0.3)]"></div><div className="w-2 h-2 rounded-[1px] bg-[rgba(124,111,247,0.6)]"></div><div className="w-2 h-2 rounded-[1px] bg-[#7C6FF7]"></div></span> Více</span>
                      </div>
                      <div className="flex gap-[3px] overflow-x-auto no-scrollbar pb-1">
                        {heatmapData.map((week, i) => (
                          <div key={i} className="flex flex-col gap-[3px]">
                            {week.map((level, j) => (
                              <div key={j} className={`w-[10px] h-[10px] sm:w-3 sm:h-3 rounded-[2px] heat-${level} hover:ring-1 hover:ring-white transition-all cursor-pointer`} title={`${level * 5} karet`}></div>
                            ))}
                          </div>
                        ))}
                      </div>
                    </div>
                  </FadeUp>
                </section>

                {/* СЕКЦИЯ 4: Kartičky & Slabiny */}
                <section className="grid grid-cols-1 md:grid-cols-2 gap-8">
                  
                  {/* Leva: Na dnes */}
                  <FadeUp>
                    <div className="flex justify-between items-center mb-6">
                      <h2 className="text-xl font-display font-medium flex items-center gap-2">
                        Kartičky na dnes <span className="text-sm font-mono bg-app-sec px-2 py-0.5 rounded text-app-muted">{TOTAL_DAILY - currentDone + completedCards.length}</span>
                      </h2>
                      <button className="text-sm text-[#7C6FF7] hover:underline flex items-center gap-1 font-medium">Začít vše <ArrowRight size={14}/></button>
                    </div>

                    <div className="flex flex-col gap-4">
                      <div className="flex flex-col gap-2">
                        <div className="text-xs uppercase tracking-wider font-bold text-[#F87171] mb-1 flex items-center gap-2">
                          <div className="w-2 h-2 rounded-full bg-[#F87171]"></div> Těžké (2)
                        </div>
                        <CardRow title="Co je determinant matice?" color="#F87171" delay={100} completed={completedCards.includes('Co je determinant matice?')} onToggle={toggleCard} />
                        <CardRow title="Definice limity funkce" color="#F87171" delay={180} completed={completedCards.includes('Definice limity funkce')} onToggle={toggleCard} />
                      </div>
                      
                      <div className="h-[1px] w-full bg-white/5 my-2"></div>
                      
                      <div className="flex flex-col gap-2">
                        <div className="text-xs uppercase tracking-wider font-bold text-[#FB923C] mb-1 flex items-center gap-2">
                          <div className="w-2 h-2 rounded-full bg-[#FB923C]"></div> Střední (10)
                        </div>
                        <CardRow title="Pythagorova věta" color="#FB923C" delay={260} completed={completedCards.includes('Pythagorova věta')} onToggle={toggleCard} />
                        <CardRow title="React useEffect hook" color="#FB923C" delay={340} completed={completedCards.includes('React useEffect hook')} onToggle={toggleCard} />
                        <div className="text-center py-2 text-xs text-app-muted bg-white/5 rounded-lg border border-white/5 hover:bg-white/10 cursor-pointer transition-colors mt-1">
                          Zobrazit dalších 8
                        </div>
                      </div>
                    </div>
                  </FadeUp>

                  {/* Prava: Slabiny */}
                  <FadeUp delay={100} className="bg-[#161B27]/50 border border-[#F87171]/20 rounded-2xl p-6 relative overflow-hidden h-fit">
                    <div className="absolute top-0 right-0 p-3 opacity-10">
                      <Activity size={100} className="text-[#F87171]" />
                    </div>
                    <h2 className="text-xl font-display font-medium text-white mb-6 flex items-center gap-2 relative z-10">
                      Nejslabší kartičky <Flame size={18} className="text-[#F87171]" />
                    </h2>
                    
                    <div className="flex flex-col gap-5 relative z-10 mb-8">
                      <WeakCard title="Co je to rekurze?" value={40} />
                      <WeakCard title="Fourierova transformace" value={30} />
                      <WeakCard title="Taylorův rozvoj" value={20} />
                    </div>

                    <button className="w-full py-3 bg-[#F87171]/10 text-[#F87171] hover:bg-[#F87171]/20 transition-colors rounded-xl font-medium flex items-center justify-center gap-2 border border-[#F87171]/20 focus:outline-none focus:ring-2 focus:ring-[#F87171]/50 relative z-10">
                      Procvičit slabá místa <ArrowRight size={16}/>
                    </button>
                  </FadeUp>
                </section>

                {/* СЕКЦИЯ 5: Rychlé akce */}
                <section>
                  <FadeUp delay={100}>
                    <h2 className="text-xl font-display font-medium mb-4">Rychlé akce</h2>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                      <FastAction icon={<FileText size={24} className="text-[#4F9CF9]"/>} text="Nová poznámka"/>
                      <FastAction icon={<Layers size={24} className="text-[#7C6FF7]"/>} text="Nová kartička"/>
                      <FastAction icon={<CheckSquare size={24} className="text-[#4ADE80]"/>} text="Nový test"/>
                      <FastAction icon={<BookOpen size={24} className="text-[#FB923C]"/>} text="Nový kurz"/>
                    </div>
                  </FadeUp>
                </section>

                {/* СЕКЦИЯ 6: Pokračuj tam, kde jsi skončil */}
                <section className="mb-10">
                  <div className="flex justify-between items-end mb-6">
                    <FadeUp><h2 className="text-2xl font-display font-medium">Pokračuj tam, kde jsi skončil</h2></FadeUp>
                    <div className="hidden sm:flex gap-2">
                      <button onClick={scrollLeft} className="w-8 h-8 rounded-full bg-app-sec flex items-center justify-center hover:bg-app-ter transition-colors border border-white/5"><ChevronLeft size={16}/></button>
                      <button onClick={scrollRight} className="w-8 h-8 rounded-full bg-app-sec flex items-center justify-center hover:bg-app-ter transition-colors border border-white/5"><ChevronRight size={16}/></button>
                    </div>
                  </div>

                  <FadeUp delay={100} className="relative">
                    <div ref={scrollRef} className="flex gap-4 overflow-x-auto no-scrollbar pb-4 snap-x snap-mandatory">
                      <ContinueCard color="#4F9CF9" course="Lineární algebra" topic="Matice" progress={67} cards={5} tests={1} time="včera" />
                      <ContinueCard color="#4ADE80" course="Programování" topic="React hooks" progress={30} cards={12} tests={0} time="před 2 dny" />
                      <ContinueCard color="#7C6FF7" course="Angličtina" topic="Phrasal verbs" progress={90} cards={2} tests={1} time="před týdnem" />
                      <ContinueCard color="#FB923C" course="Dějepis" topic="1. světová válka" progress={15} cards={24} tests={0} time="před 2 týdny" />
                    </div>
                  </FadeUp>
                </section>

              </div>
            </div>
          </div>
        </div>
      );
    }

    // --- ВСПОМОГАТЕЛЬНЫЕ КОМПОНЕНТЫ ---

    const NavItem = ({ icon, label, badge, active, sidebarOpen, onClick }) => (
      <div onClick={onClick} className={`nav-item flex items-center gap-3 p-2.5 rounded-lg cursor-pointer transition-colors group ${active ? 'active' : ''}`}>
        <div className={`${active ? 'text-[#7C6FF7]' : 'text-app-muted group-hover:text-white'} transition-colors`}>{icon}</div>
        {sidebarOpen && (
          <>
            <span className={`text-sm font-medium transition-colors ${active ? 'text-white' : 'text-app-sec group-hover:text-white'}`}>{label}</span>
            {badge && <span className="ml-auto bg-[#F87171] text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full">{badge}</span>}
          </>
        )}
      </div>
    );

    const TreeItem = ({ title, color, open, cards }) => (
      <div className="flex flex-col">
        <div className="flex items-center gap-2 p-1.5 hover:bg-white/5 rounded cursor-pointer group">
          <div className={`w-3 h-3 rounded-[3px] border`} style={{ borderColor: color, backgroundColor: open ? color : 'transparent' }}></div>
          <span className="text-app-sec group-hover:text-white transition-colors truncate">{title}</span>
        </div>
        {open && (
          <div className="ml-2 pl-3 border-l border-white/10 flex flex-col gap-1 mt-1">
            <div className="flex items-start gap-2 p-1 text-xs text-app-muted hover:text-app-sec cursor-pointer">
              <FileText size={12} className="mt-0.5" /> <span className="truncate">Matice</span> {cards > 0 && <span className="ml-auto bg-white/5 px-1 rounded">[{cards}🃏]</span>}
            </div>
            <div className="flex items-start gap-2 p-1 text-xs text-app-muted hover:text-app-sec cursor-pointer">
              <FileText size={12} className="mt-0.5" /> <span className="truncate">Vektory</span> <span className="ml-auto bg-white/5 px-1 rounded">[3🃏]</span>
            </div>
          </div>
        )}
      </div>
    );

    const ContinueCard = ({ color, course, topic, progress, cards, tests, time }) => (
      <div className="min-w-[260px] snap-center shrink-0 bg-app-sec border border-white/5 rounded-2xl p-5 flex flex-col group hover:-translate-y-2 transition-all duration-300 hover:shadow-[0_10px_30px_rgba(0,0,0,0.5)] hover:border-white/15 cursor-pointer relative overflow-hidden">
        <div className="absolute top-0 left-0 w-full h-1" style={{ backgroundColor: color }}></div>
        <div className="text-xs font-medium mb-1 mt-1" style={{ color }}>{course}</div>
        <div className="text-lg font-display font-medium text-white mb-4">{topic}</div>
        
        <div className="text-xs text-app-sec mb-2">Otevřeno {time}</div>
        <div className="flex gap-2 text-[10px] text-app-muted mb-4 font-medium uppercase tracking-wider">
          <span className="bg-app-ter px-2 py-0.5 rounded">{cards} kartiček</span>
          {tests > 0 && <span className="bg-app-ter px-2 py-0.5 rounded">{tests} test</span>}
        </div>

        <div className="mt-auto">
          <div className="flex justify-between text-[10px] text-app-sec mb-1 font-mono">
            <span>Průchod</span>
            <span style={{ color }}>{progress}%</span>
          </div>
          <div className="h-1.5 w-full bg-app-ter rounded-full overflow-hidden">
            <div className="h-full rounded-full transition-all duration-1000" style={{ width: `${progress}%`, backgroundColor: color }}></div>
          </div>
        </div>
        
        <div className="absolute -bottom-12 left-0 w-full p-4 bg-gradient-to-t from-[#161B27] via-[#161B27]/80 to-transparent opacity-0 group-hover:opacity-100 group-hover:bottom-0 transition-all flex justify-center backdrop-blur-[2px]">
          <span className="text-xs font-medium flex items-center gap-1" style={{ color }}>Otevřít <ArrowRight size={12}/></span>
        </div>
      </div>
    );

    const CardRow = ({ title, color, delay, completed, onToggle }) => (
      <FadeUp delay={delay}>
        <div className={`group flex justify-between items-center border border-white/5 rounded-xl p-3 transition-all cursor-default ${completed ? 'bg-[#4ADE80]/5 border-[#4ADE80]/20' : 'bg-app-sec hover:bg-white/5'}`}>
          <div className="flex items-center gap-3">
            <div className={`w-1.5 h-1.5 rounded-full shrink-0 transition-colors`} style={{ backgroundColor: completed ? '#4ADE80' : color }}></div>
            <span className={`text-sm font-medium transition-colors line-clamp-1 ${completed ? 'line-through text-app-muted' : 'text-app-text group-hover:text-white'}`}>{title}</span>
          </div>
          <button onClick={() => onToggle && onToggle(title)} className={`text-xs font-medium px-3 py-1.5 rounded transition-all shrink-0 ${completed ? 'bg-[#4ADE80]/10 text-[#4ADE80]' : 'bg-app-ter text-app-sec hover:text-white hover:bg-white/10 opacity-0 group-hover:opacity-100'}`}>
            {completed ? '✓ Hotovo' : 'Zopakovat'}
          </button>
        </div>
      </FadeUp>
    );

    const WeakCard = ({ title, value }) => (
      <div className="flex flex-col gap-1.5">
        <div className="text-sm text-app-sec truncate">{title}</div>
        <div className="flex items-center gap-3">
          <div className="flex-1 h-2 bg-app-bg rounded-full overflow-hidden">
            <div className="h-full bg-gradient-to-r from-[#F87171] to-[#FB923C] rounded-full" style={{ width: `${value}%` }}></div>
          </div>
          <span className="text-[10px] font-mono text-[#F87171] w-8 text-right">{value}%</span>
        </div>
      </div>
    );

    const FastAction = ({ icon, text }) => (
      <button className="bg-app-sec hover:bg-white/5 border border-white/5 hover:border-white/10 rounded-xl p-4 flex flex-col items-center justify-center gap-2 fast-action-tile cursor-pointer shadow-sm relative overflow-hidden group w-full h-full min-h-[100px]">
        <div className="relative z-10">{icon}</div>
        <span className="text-xs font-medium text-app-sec group-hover:text-white transition-colors relative z-10">{text}</span>
      </button>
    );

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<Dashboard />);
  </script>
</body>
</html>
